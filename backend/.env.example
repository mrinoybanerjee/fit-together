PORT=3001
JWT_SECRET=change-me-to-a-long-random-string

# ── Whoop API (Partner 1) ───────────────────────────────────────────
# Register at https://developer.whoop.com → OAuth2 app
# After setting CLIENT_ID + SECRET, visit http://localhost:3001/api/whoop/auth
# to authorize and get your access token.
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=
WHOOP_REDIRECT_URI=http://localhost:3001/api/whoop/callback
WHOOP_ACCESS_TOKEN=
WHOOP_REFRESH_TOKEN=

# ── Terra API (Partner 2 — Apple Watch bridge) ──────────────────────
# Sign up at https://tryterra.co (free tier: 100 calls/day)
# Create a project → copy API key + dev ID here
TERRA_API_KEY=
TERRA_DEV_ID=

# ── Partner display names ───────────────────────────────────────────
PARTNER1_NAME=Alex
PARTNER2_NAME=Sam
